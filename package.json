{
  "name": "xapi-coaching-app",
  "version": "1.0.0",
  "description": "Classify coaching/meeting transcripts against a user-defined metric with Claude or Gemini and route results to an LRS via xAPI",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "node --env-file-if-exists=.env server.js",
    "classify": "node --env-file-if-exists=.env test/run-classify.mjs",
    "classify:local": "LLM_MODE=local node test/run-classify.mjs test/fixtures/coaching-transcript.txt coaching",
    "eval": "node --env-file-if-exists=.env eval/run-eval.mjs",
    "eval:local": "LLM_MODE=local node eval/run-eval.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@netlify/blobs": "^10.7.9",
    "express": "^4.21.0"
  }
}
