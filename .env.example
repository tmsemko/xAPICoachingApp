# Copy to .env and fill in your keys (.env is gitignored).
# On Netlify, set these under Site configuration → Environment variables.

# --- LLM provider (set one or both keys; LLM_PROVIDER picks when both exist) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# LLM_PROVIDER=claude            # claude | gemini
# CLASSIFIER_MODEL=claude-sonnet-5

# --- LRS (server-side defaults; UI fields override when filled in) ---
LRS_ENDPOINT=https://sample-lrs-iguname.lrs.io/xapi/
LRS_KEY=
LRS_SECRET=
